{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-docs/refs/heads/main/github.com/tauri-apps/tauri-docs/tauri.conf.json",
  "productName": "Grid Screen",
  "version": "0.1.0",
  "identifier": "com.gridscreen.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Grid Screen",
        "width": 1024,
        "height": 640,
        "decorations": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  }
}
